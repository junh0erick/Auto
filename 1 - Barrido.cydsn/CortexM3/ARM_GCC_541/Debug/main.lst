  14:main.c        **** #define MOTOR_MAX           PWM_PERIOD
  15:main.c        **** #define MOTOR_MIN           -PWM_PERIOD
  16:main.c        **** 
  17:main.c        **** // Encoder del motor: cuentas por revolución mecánica
  18:main.c        **** // QuadDec usa modo x4 → si el encoder tiene N PPR, CPR = 4*N
  19:main.c        **** // Ajustar según el encoder físico utilizado
  20:main.c        **** #define ENCODER_CPR         1040u
  21:main.c        **** 
  22:main.c        **** // Tiempo de muestreo en segundos.
  23:main.c        **** // clk_Timer = 24 MHz, period = 240000 cuentas
  24:main.c        **** //   T = 240000 / 24000000 = 0.01 s  (10 ms)
  25:main.c        **** #define SAMPLE_TIME_S       0.01f
  26:main.c        **** 
