  39:main.c        **** #define PWM_P5   1.250859e+02f
  40:main.c        **** 
  41:main.c        **** /*******************************************************************************
  42:main.c        **** * POLINOMIO DE AJUSTE — RPM estimado a partir del PWM
  43:main.c        **** * Usa el método de Horner para minimizar operaciones
  44:main.c        **** *******************************************************************************/
  45:main.c        **** 
  46:main.c        **** float RPM_Estimado(int16 pwm)
  47:main.c        **** {
  48:main.c        ****     float x = (float)pwm;
  49:main.c        ****     return (((RPM_P1 * x + RPM_P2) * x + RPM_P3) * x + RPM_P4) * x + RPM_P5;
  50:main.c        **** }
  51:main.c        **** 
  52:main.c        **** int16 PWM_Desde_Voltaje(float v)
  53:main.c        **** {
  54:main.c        ****     int16 pwm = (int16)((((PWM_P1 * v + PWM_P2) * v + PWM_P3) * v + PWM_P4) * v + PWM_P5);
  55:main.c        ****     if (pwm > MOTOR_MAX) pwm = MOTOR_MAX;
  56:main.c        ****     if (pwm < 0)         pwm = 0;
  57:main.c        ****     return pwm;
  58:main.c        **** }
  59:main.c        **** 
  60:main.c        **** /*******************************************************************************
