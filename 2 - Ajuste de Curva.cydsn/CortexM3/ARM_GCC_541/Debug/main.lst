  31:main.c        **** #define RPM_P4   1.611e-03f
  32:main.c        **** #define RPM_P5  -8.532e-01f
  33:main.c        **** 
  34:main.c        **** // Coeficientes Poly4: PWM = f(Voltaje)
  35:main.c        **** #define PWM_P1  -1.101764e-01f
