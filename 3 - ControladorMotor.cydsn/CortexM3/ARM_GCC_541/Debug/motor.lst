  74:motor.c       **** void Motor_Controller_Run(void)
  75:motor.c       **** {
  76:motor.c       ****     int32 current_count = QuadDec_1_GetCounter();
ARM GAS  C:\Users\user\AppData\Local\Temp\ccDg6Blx.s 			page 6


  77:motor.c       ****     int32 delta_counts  = current_count - encoder_prev_count;
  78:motor.c       ****     encoder_prev_count  = current_count;
  79:motor.c       **** 
  80:motor.c       ****     motor_speed_rpm  = ((float)delta_counts * 60.0f) /
  81:motor.c       ****                        ((float)ENCODER_CPR * SAMPLE_TIME_S);
  82:motor.c       ****     motor_speed_rads = motor_speed_rpm * (3.14159265f / 30.0f);
  83:motor.c       **** 
  84:motor.c       ****     /* Setpoint = 0: liberar motor y resetear PI para evitar windup */
