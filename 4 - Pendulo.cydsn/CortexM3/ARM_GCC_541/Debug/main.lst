   1:main.c        **** /* ============================================================
   2:main.c        ****    main.c — Péndulo Invertido PSoC 5LP  v3
   3:main.c        ****    Nueva arquitectura: PSoC = sensor/actuador únicamente.
   4:main.c        ****    MATLAB ejecuta todo el control en doble precisión.
   5:main.c        **** 
   6:main.c        ****    Protocolo (uartp_pend):
   7:main.c        ****      COMMAND mode:
   8:main.c        ****        'r' → 'K'                         Reset
   9:main.c        ****        'f' → 'R' → [Fs f32 4B handshake] → 'K'   Configurar Fs_inner
  10:main.c        ****        'i' → 'K'                         Iniciar CONTROL mode
  11:main.c        ****        's' → 'K'                         Stop
  12:main.c        **** 
  13:main.c        ****      CONTROL mode (ciclo por Ts_inner):
  14:main.c        ****        PSoC → MATLAB : [theta int32 LE (4B)][delta_om int16 LE (2B)] = 6 bytes
  15:main.c        ****        MATLAB → PSoC : [u_pwm int16 LE (2B)] = 2 bytes
  16:main.c        ****        's' (byte solitario) → 'K'        Stop (vuelve a COMMAND)
  17:main.c        ****    ============================================================ */
  18:main.c        **** #include "project.h"
  19:main.c        **** #include "pendulo.h"
  20:main.c        **** #include "motor.h"
  21:main.c        **** #include "uartp_pend.h"
  22:main.c        **** 
