   1:main.c        **** /* ============================================================
   2:main.c        ****    main.c — Péndulo Invertido PSoC 5LP (on-PSoC two-plant control)
   3:main.c        ****    CTRL-mode commands: 's' stop, 'f' live inner reference update (4B raw float)
   4:main.c        **** 
   5:main.c        ****    Architecture:
   6:main.c        ****      PSoC reads encoders, runs TF/SS/OL controllers for both
   7:main.c        ****      plants, drives motor, and streams telemetry to MATLAB.
   8:main.c        ****      MATLAB configures controllers via UARTP2 protocol.
   9:main.c        **** 
  10:main.c        ****    Plants:
  11:main.c        ****      Plant 0 (inner): u_pwm → ω_motor   [rad/s]   (QuadDec_1)
  12:main.c        ****      Plant 1 (outer): u_ref → θ_pendulum [rad]      (QuadDec_2)
  13:main.c        **** 
  14:main.c        ****    Protocol: see uartp2.h
  15:main.c        ****    Telemetry: 16 B/tick [y2_f32 u1_f32 y1_f32 u2_f32]
  16:main.c        ****    ============================================================ */
