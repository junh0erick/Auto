   1:main.c        **** /* ============================================================
   2:main.c        ****    main.c — Péndulo Invertido PSoC 5LP  v5
   3:main.c        ****    Arquitectura: PSoC = sensor/actuador, MATLAB = control.
   4:main.c        **** 
   5:main.c        ****    Protocolo (uartp_pend):
   6:main.c        ****      COMMAND mode:
   7:main.c        ****        'r' → 'K'                          Reset
   8:main.c        ****        'f' → 'R' → [Fs f32 4B handshake] → 'K'   Configurar timer
   9:main.c        ****        'i' → 'K'                          Iniciar CONTROL mode
  10:main.c        ****        's' → 'K'                          Stop (también desde CONTROL)
  11:main.c        **** 
  12:main.c        ****      CONTROL mode (request-response por muestra):
  13:main.c        ****        MATLAB → PSoC : 'g'               Solicitar muestra
  14:main.c        ****        PSoC → MATLAB : [theta int32 LE (4B)][delta_om int16 LE (2B)] = 6 bytes
  15:main.c        ****        MATLAB → PSoC : [u_pwm int16 LE (2B)]  → Motor_Control()
  16:main.c        ****        Stop: 's' en estado 0 → Motor_Free + 'K' + vuelve a COMMAND
  17:main.c        ****    ============================================================ */
  18:main.c        **** #include "project.h"
  19:main.c        **** #include "pendulo.h"
  20:main.c        **** #include "motor.h"
  21:main.c        **** #include "uartp_pend.h"
