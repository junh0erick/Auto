   1:main.c        **** /* ============================================================
   2:main.c        ****    main.c — Péndulo Invertido PSoC 5LP (on-PSoC two-plant control)
   3:main.c        **** 
   4:main.c        ****    Architecture:
   5:main.c        ****      PSoC reads encoders, runs TF/SS/OL controllers for both
   6:main.c        ****      plants, drives motor, and streams telemetry to MATLAB.
   7:main.c        ****      MATLAB configures controllers via UARTP2 protocol.
   8:main.c        **** 
   9:main.c        ****    Plants:
  10:main.c        ****      Plant 0 (inner): u_pwm → ω_motor   [rad/s]   (QuadDec_1)
  11:main.c        ****      Plant 1 (outer): u_ref → θ_pendulum [rad]      (QuadDec_2)
  12:main.c        **** 
  13:main.c        ****    Protocol: see uartp2.h
  14:main.c        ****    Telemetry: 16 B/tick [u1_f32 y1_f32 u2_f32 y2_f32]
  15:main.c        ****    ============================================================ */
  16:main.c        **** #include "project.h"
  17:main.c        **** #include "pendulo.h"
  18:main.c        **** #include "motor.h"
  19:main.c        **** #include "ctrl_pend.h"
