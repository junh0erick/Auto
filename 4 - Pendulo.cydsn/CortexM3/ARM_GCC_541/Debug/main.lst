  27              		.file 1 "main.c"
   1:main.c        **** /* ============================================================
   2:main.c        ****    main.c — Péndulo Invertido PSoC 5LP  v6
   3:main.c        ****    Arquitectura: PSoC = control + sensor/actuador, MATLAB = display.
   4:main.c        **** 
   5:main.c        ****    Protocolo (uartp_pend):
   6:main.c        ****      COMMAND mode:
   7:main.c        ****        'r' → 'K'                          Reset
   8:main.c        ****        'f' → 'R' → [Fs f32 4B handshake] → 'K'   Compatibilidad
   9:main.c        ****        'p' → [len 2B LE][216B payload][xsum] → 'K'/'E'  Set params
  10:main.c        ****        'i' → 'K'                          Iniciar STREAM mode
  11:main.c        ****        's' → 'K'                          Stop
  12:main.c        **** 
  13:main.c        ****      STREAM mode (PSoC-driven, v6):
  14:main.c        ****        PSoC → MATLAB: 8×float32 LE = 32 bytes/tick
  15:main.c        ****        MATLAB → PSoC: 'u' + [ref f32]     Actualizar referencia inner
  16:main.c        ****                       's'                  Stop
  17:main.c        **** 
  18:main.c        ****    Telemetría 32 bytes por tick:
  19:main.c        ****        y1   = omega [rad/s]   (float32 LE)
  20:main.c        ****        y2   = theta [rad]     (float32 LE)
  21:main.c        ****        u1   = esfuerzo PWM    (float32 LE, sin saturar)
  22:main.c        ****        u2   = ref inner       (float32 LE, salida outer o ref manual)
  23:main.c        ****        x1i  = inner xhat[0]  (float32 LE)
  24:main.c        ****        x2i  = inner xhat[1]  (float32 LE)
  25:main.c        ****        x1o  = outer xhat[0]  (float32 LE)
  26:main.c        ****        x2o  = outer xhat[1]  (float32 LE)
  27:main.c        ****    ============================================================ */
  28:main.c        **** #include "project.h"
  29:main.c        **** #include "pendulo.h"
  30:main.c        **** #include "motor.h"
