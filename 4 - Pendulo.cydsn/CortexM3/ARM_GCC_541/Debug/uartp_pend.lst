 182:uartp_pend.c  **** /* ============================================================
 183:uartp_pend.c  ****    UARTP_Init()
 184:uartp_pend.c  ****    ============================================================ */
 185:uartp_pend.c  **** void UARTP_Init(void)
 186:uartp_pend.c  **** {
 187:uartp_pend.c  ****     UART_1_Start();
 188:uartp_pend.c  ****     isr_2_StartEx(UARTP_Rx_ISR);    /* conectar ISR al rx_interrupt de UART_1 */
 189:uartp_pend.c  ****     UARTP_SysMode  = UARTP_SYS_COMMAND;
 190:uartp_pend.c  ****     s_rx_state     = RX_IDLE;
 191:uartp_pend.c  ****     s_rx_ucnt      = 0u;
 192:uartp_pend.c  **** }
 193:uartp_pend.c  **** 
 194:uartp_pend.c  **** /* ============================================================
 195:uartp_pend.c  ****    UARTP_ProcessCommand()
 196:uartp_pend.c  ****    Procesa UN comando en modo COMMAND.
 197:uartp_pend.c  ****    Llamar repetidamente desde el loop principal.
 198:uartp_pend.c  ****    ============================================================ */
 199:uartp_pend.c  **** void UARTP_ProcessCommand(void)
 200:uartp_pend.c  **** {
 201:uartp_pend.c  ****     uint8 cmd;
 202:uartp_pend.c  ****     uint8 payload[4];
 203:uartp_pend.c  ****     float fs_hz;
 204:uartp_pend.c  ****     uint8 *pf;
 205:uartp_pend.c  **** 
 206:uartp_pend.c  ****     if (UART_1_GetRxBufferSize() == 0u) return;
 207:uartp_pend.c  **** 
 208:uartp_pend.c  ****     cmd = UART_1_ReadRxData();
 209:uartp_pend.c  **** 
 210:uartp_pend.c  ****     switch (cmd)
 211:uartp_pend.c  ****     {
 212:uartp_pend.c  ****         /* ---- Reset ---- */
 213:uartp_pend.c  ****         case (uint8)'r':
 214:uartp_pend.c  ****             Motor_Free();
 215:uartp_pend.c  ****             ctrl_stop();
 216:uartp_pend.c  ****             g_flag_control   = 0u;
 217:uartp_pend.c  ****             UARTP_SysMode    = UARTP_SYS_COMMAND;
 218:uartp_pend.c  ****             UARTP_PendingRef = 0.0f;
 219:uartp_pend.c  ****             s_rx_state       = RX_IDLE;
 220:uartp_pend.c  ****             ll_putchar((uint8)'K');
 221:uartp_pend.c  ****             break;
 222:uartp_pend.c  **** 
 223:uartp_pend.c  ****         /* ---- Set Fs_inner (compatibilidad) ---- */
 224:uartp_pend.c  ****         case (uint8)'f':
 225:uartp_pend.c  ****             ll_putchar((uint8)'R');
 226:uartp_pend.c  ****             if (ll_recv_word4(payload))
 227:uartp_pend.c  ****             {
 228:uartp_pend.c  ****                 pf    = (uint8*)&fs_hz;
 229:uartp_pend.c  ****                 pf[0] = payload[0]; pf[1] = payload[1];
 230:uartp_pend.c  ****                 pf[2] = payload[2]; pf[3] = payload[3];
 231:uartp_pend.c  ****                 /* Actualizar timer directamente */
 232:uartp_pend.c  ****                 if (fs_hz > 0.5f && fs_hz <= 10000.0f) {
 233:uartp_pend.c  ****                     uint32 period = (uint32)((float)TIMER_CLOCK_HZ / fs_hz) - 1u;
 234:uartp_pend.c  ****                     Timer_1_Stop();
 235:uartp_pend.c  ****                     Timer_1_WritePeriod(period);
 236:uartp_pend.c  ****                     Timer_1_Start();
ARM GAS  C:\Users\user\AppData\Local\Temp\ccCuvtba.s 			page 15


 237:uartp_pend.c  ****                 }
 238:uartp_pend.c  ****                 ll_putchar((uint8)'K');
 239:uartp_pend.c  ****             }
 240:uartp_pend.c  ****             else
 241:uartp_pend.c  ****             {
 242:uartp_pend.c  ****                 ll_putchar((uint8)'!');
 243:uartp_pend.c  ****             }
 244:uartp_pend.c  ****             break;
 245:uartp_pend.c  **** 
 246:uartp_pend.c  ****         /* ---- Set params (NUEVO v6) ---- */
 247:uartp_pend.c  ****         case (uint8)'p':
 248:uartp_pend.c  ****             handle_cmd_p();
 249:uartp_pend.c  ****             break;
 250:uartp_pend.c  **** 
 251:uartp_pend.c  ****         /* ---- Verificar params almacenados (eco de s_p_buf) ---- */
 252:uartp_pend.c  ****         /* MATLAB envía 'v' tras 'p' para confirmar que el PSoC almacenó         */
 253:uartp_pend.c  ****         /* exactamente lo que se envió. PSoC responde: [216 bytes] + [xsum XOR]. */
 254:uartp_pend.c  ****         case (uint8)'v':
 255:uartp_pend.c  ****         {
 256:uartp_pend.c  ****             uint16 vi;
 257:uartp_pend.c  ****             uint8  vxs = 0u;
 258:uartp_pend.c  ****             for (vi = 0u; vi < P_PAYLOAD_SZ; vi++) {
 259:uartp_pend.c  ****                 ll_putchar(s_p_buf[vi]);
 260:uartp_pend.c  ****                 vxs ^= s_p_buf[vi];
 261:uartp_pend.c  ****             }
 262:uartp_pend.c  ****             ll_putchar(vxs);   /* checksum del payload almacenado */
 263:uartp_pend.c  ****             break;
 264:uartp_pend.c  ****         }
 265:uartp_pend.c  **** 
 266:uartp_pend.c  ****         /* ---- Iniciar STREAM (control en PSoC) ---- */
 267:uartp_pend.c  ****         case (uint8)'i':
 268:uartp_pend.c  ****             Motor_Free();
 269:uartp_pend.c  ****             g_flag_control = 0u;
 270:uartp_pend.c  ****             s_rx_state     = RX_IDLE;
 271:uartp_pend.c  ****             s_rx_ucnt      = 0u;
