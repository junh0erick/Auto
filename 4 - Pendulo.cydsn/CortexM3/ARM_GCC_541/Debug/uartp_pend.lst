  14:uartp_pend.c  **** /* ============================================================
  15:uartp_pend.c  ****    Estado interno del parser RX en modo CONTROL
  16:uartp_pend.c  ****    Máquina de estados de 2 bytes:
  17:uartp_pend.c  ****      IDLE       → espera primer byte de u_pwm (o 's' para stop)
  18:uartp_pend.c  ****      GOT_LSB    → ya tiene u_lsb, espera u_msb
  19:uartp_pend.c  ****    ============================================================ */
  20:uartp_pend.c  **** #define RX_IDLE    0u
  21:uartp_pend.c  **** #define RX_GOT_LSB 1u
  22:uartp_pend.c  **** static uint8 s_rx_state = RX_IDLE;
  23:uartp_pend.c  **** static uint8 s_rx_lsb   = 0u;
  24:uartp_pend.c  **** 
