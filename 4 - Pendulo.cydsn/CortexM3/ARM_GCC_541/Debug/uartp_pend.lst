 177:uartp_pend.c  **** /* ============================================================
 178:uartp_pend.c  ****    UARTP_Init()
 179:uartp_pend.c  ****    ============================================================ */
 180:uartp_pend.c  **** void UARTP_Init(void)
 181:uartp_pend.c  **** {
 182:uartp_pend.c  ****     UART_1_Start();
 183:uartp_pend.c  ****     isr_2_StartEx(UARTP_Rx_ISR);    /* conectar ISR al rx_interrupt de UART_1 */
 184:uartp_pend.c  ****     UARTP_SysMode  = UARTP_SYS_COMMAND;
 185:uartp_pend.c  ****     s_rx_state     = RX_IDLE;
 186:uartp_pend.c  ****     s_rx_ucnt      = 0u;
 187:uartp_pend.c  **** }
 188:uartp_pend.c  **** 
 189:uartp_pend.c  **** /* ============================================================
 190:uartp_pend.c  ****    UARTP_ProcessCommand()
 191:uartp_pend.c  ****    Procesa UN comando en modo COMMAND.
 192:uartp_pend.c  ****    Llamar repetidamente desde el loop principal.
 193:uartp_pend.c  ****    ============================================================ */
 194:uartp_pend.c  **** void UARTP_ProcessCommand(void)
 195:uartp_pend.c  **** {
 196:uartp_pend.c  ****     uint8 cmd;
 197:uartp_pend.c  ****     uint8 payload[4];
 198:uartp_pend.c  ****     float fs_hz;
 199:uartp_pend.c  ****     uint8 *pf;
 200:uartp_pend.c  **** 
 201:uartp_pend.c  ****     if (UART_1_GetRxBufferSize() == 0u) return;
 202:uartp_pend.c  **** 
 203:uartp_pend.c  ****     cmd = UART_1_ReadRxData();
ARM GAS  C:\Users\user\AppData\Local\Temp\cc5AR3xz.s 			page 14


 204:uartp_pend.c  **** 
 205:uartp_pend.c  ****     switch (cmd)
 206:uartp_pend.c  ****     {
 207:uartp_pend.c  ****         /* ---- Reset ---- */
 208:uartp_pend.c  ****         case (uint8)'r':
 209:uartp_pend.c  ****             Motor_Free();
 210:uartp_pend.c  ****             ctrl_stop();
 211:uartp_pend.c  ****             g_flag_control   = 0u;
 212:uartp_pend.c  ****             UARTP_SysMode    = UARTP_SYS_COMMAND;
 213:uartp_pend.c  ****             UARTP_PendingRef = 0.0f;
 214:uartp_pend.c  ****             s_rx_state       = RX_IDLE;
 215:uartp_pend.c  ****             ll_putchar((uint8)'K');
 216:uartp_pend.c  ****             break;
 217:uartp_pend.c  **** 
 218:uartp_pend.c  ****         /* ---- Set Fs_inner (compatibilidad) ---- */
 219:uartp_pend.c  ****         case (uint8)'f':
 220:uartp_pend.c  ****             ll_putchar((uint8)'R');
 221:uartp_pend.c  ****             if (ll_recv_word4(payload))
 222:uartp_pend.c  ****             {
 223:uartp_pend.c  ****                 pf    = (uint8*)&fs_hz;
 224:uartp_pend.c  ****                 pf[0] = payload[0]; pf[1] = payload[1];
 225:uartp_pend.c  ****                 pf[2] = payload[2]; pf[3] = payload[3];
 226:uartp_pend.c  ****                 /* Actualizar timer directamente */
 227:uartp_pend.c  ****                 if (fs_hz > 0.5f && fs_hz <= 10000.0f) {
 228:uartp_pend.c  ****                     uint32 period = (uint32)((float)TIMER_CLOCK_HZ / fs_hz) - 1u;
 229:uartp_pend.c  ****                     Timer_1_Stop();
 230:uartp_pend.c  ****                     Timer_1_WritePeriod(period);
 231:uartp_pend.c  ****                     Timer_1_Start();
 232:uartp_pend.c  ****                 }
 233:uartp_pend.c  ****                 ll_putchar((uint8)'K');
 234:uartp_pend.c  ****             }
 235:uartp_pend.c  ****             else
 236:uartp_pend.c  ****             {
 237:uartp_pend.c  ****                 ll_putchar((uint8)'!');
 238:uartp_pend.c  ****             }
 239:uartp_pend.c  ****             break;
 240:uartp_pend.c  **** 
 241:uartp_pend.c  ****         /* ---- Set params (NUEVO v6) ---- */
 242:uartp_pend.c  ****         case (uint8)'p':
 243:uartp_pend.c  ****             handle_cmd_p();
 244:uartp_pend.c  ****             break;
 245:uartp_pend.c  **** 
 246:uartp_pend.c  ****         /* ---- Verificar params almacenados (eco de s_p_buf) ---- */
 247:uartp_pend.c  ****         /* MATLAB envía 'v' tras 'p' para confirmar que el PSoC almacenó         */
 248:uartp_pend.c  ****         /* exactamente lo que se envió. PSoC responde: [216 bytes] + [xsum XOR]. */
 249:uartp_pend.c  ****         case (uint8)'v':
 250:uartp_pend.c  ****         {
 251:uartp_pend.c  ****             uint16 vi;
 252:uartp_pend.c  ****             uint8  vxs = 0u;
 253:uartp_pend.c  ****             for (vi = 0u; vi < P_PAYLOAD_SZ; vi++) {
 254:uartp_pend.c  ****                 ll_putchar(s_p_buf[vi]);
 255:uartp_pend.c  ****                 vxs ^= s_p_buf[vi];
 256:uartp_pend.c  ****             }
 257:uartp_pend.c  ****             ll_putchar(vxs);   /* checksum del payload almacenado */
 258:uartp_pend.c  ****             break;
 259:uartp_pend.c  ****         }
 260:uartp_pend.c  **** 
ARM GAS  C:\Users\user\AppData\Local\Temp\cc5AR3xz.s 			page 15


 261:uartp_pend.c  ****         /* ---- Iniciar STREAM (control en PSoC) ---- */
 262:uartp_pend.c  ****         case (uint8)'i':
 263:uartp_pend.c  ****             Motor_Free();
 264:uartp_pend.c  ****             g_flag_control = 0u;
 265:uartp_pend.c  ****             s_rx_state     = RX_IDLE;
 266:uartp_pend.c  ****             s_rx_ucnt      = 0u;
 267:uartp_pend.c  ****             ctrl_start(UARTP_PendingRef);
 268:uartp_pend.c  ****             UARTP_SysMode  = UARTP_SYS_CONTROL;
 269:uartp_pend.c  ****             ll_putchar((uint8)'K');
 270:uartp_pend.c  ****             break;
 271:uartp_pend.c  **** 
 272:uartp_pend.c  ****         /* ---- Stop ---- */
 273:uartp_pend.c  ****         case (uint8)'s':
 274:uartp_pend.c  ****             Motor_Free();
 275:uartp_pend.c  ****             ctrl_stop();
 276:uartp_pend.c  ****             UARTP_SysMode = UARTP_SYS_COMMAND;
 277:uartp_pend.c  ****             ll_putchar((uint8)'K');
 278:uartp_pend.c  ****             break;
 279:uartp_pend.c  **** 
 280:uartp_pend.c  ****         default:
 281:uartp_pend.c  ****             break;
 282:uartp_pend.c  ****     }
 283:uartp_pend.c  **** }
 284:uartp_pend.c  **** 
 285:uartp_pend.c  **** /* ============================================================
 286:uartp_pend.c  ****    UARTP_Rx_ISR()
 287:uartp_pend.c  ****    ISR conectado a isr_2 → UART_1 rx_interrupt.
 288:uartp_pend.c  ****    Se ejecuta inmediatamente al llegar cada byte en STREAM mode.
 289:uartp_pend.c  ****    En COMMAND mode: no consume bytes (los deja en el buffer de UART_1
 290:uartp_pend.c  ****    para que UARTP_ProcessCommand los procese).
 291:uartp_pend.c  **** 
 292:uartp_pend.c  ****    Protocolo STREAM:
 293:uartp_pend.c  ****      's'            → stop inmediato + 'K' + vuelve a COMMAND
 294:uartp_pend.c  ****      'u' + [4B f32] → actualizar ref_inner live (sin respuesta)
 295:uartp_pend.c  ****    ============================================================ */
 296:uartp_pend.c  **** CY_ISR(UARTP_Rx_ISR)
 297:uartp_pend.c  **** {
 524              		.loc 1 297 0
