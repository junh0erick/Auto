  72:ctrl_pend.c   **** 
  73:ctrl_pend.c   ****     /* SS – estados del observador (float, siempre) */
  74:ctrl_pend.c   ****     float  xhat[2];         /* estimado posterior */
  75:ctrl_pend.c   ****     float  zhat[2];         /* estimado prior (observer actual) */
  76:ctrl_pend.c   ****     float  vint;            /* acumulador integral (float, sin Ts) */
  77:ctrl_pend.c   **** 
  78:ctrl_pend.c   ****     float  ref;             /* setpoint actual */
  79:ctrl_pend.c   ****     float  u_out;           /* salida anterior saturada (para observer) */
  80:ctrl_pend.c   **** 
  81:ctrl_pend.c   ****     /* Decimación (solo outer, planta 1) */
  82:ctrl_pend.c   ****     uint16 N;
  83:ctrl_pend.c   ****     uint16 cnt;
  84:ctrl_pend.c   **** 
  85:ctrl_pend.c   ****     /* Normalización para Q-format (c[16], default 1.0f).
  86:ctrl_pend.c   ****        Señales: x_q = float_to_q(x / q_scale).
ARM GAS  C:\Users\user\AppData\Local\Temp\ccvG3JZK.s 			page 3


