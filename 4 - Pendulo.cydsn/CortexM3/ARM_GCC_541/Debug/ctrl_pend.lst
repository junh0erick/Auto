 479:ctrl_pend.c   **** static float ss_u_cmd_q15(CtrlLoop *lp)
 480:ctrl_pend.c   **** {
 481:ctrl_pend.c   ****     float qs = lp->q_scale;
 482:ctrl_pend.c   ****     q15_t xhat_q[2];
 483:ctrl_pend.c   ****     q63_t dot;
 484:ctrl_pend.c   **** 
 485:ctrl_pend.c   ****     xhat_q[0] = flt_to_q15n(lp->xhat[0] / qs);
 486:ctrl_pend.c   ****     xhat_q[1] = flt_to_q15n(lp->xhat[1] / qs);
 487:ctrl_pend.c   **** 
 488:ctrl_pend.c   ****     arm_dot_prod_q15(lp->qK15, xhat_q, 2u, &dot);
 489:ctrl_pend.c   ****     q15_t kx = qsat15((q31_t)(dot >> 15));
 490:ctrl_pend.c   **** 
 491:ctrl_pend.c   ****     float extra_f = mode_has_i(lp->mode) ? (lp->Kx * lp->vint)
 492:ctrl_pend.c   ****                                          : (lp->Kx * lp->ref);
 493:ctrl_pend.c   ****     q15_t extra_q = flt_to_q15n(extra_f / qs);
 494:ctrl_pend.c   **** 
 495:ctrl_pend.c   ****     return q15_to_flt(qsat15((q31_t)extra_q - kx)) * qs;
 496:ctrl_pend.c   **** }
 497:ctrl_pend.c   **** 
 498:ctrl_pend.c   **** static void ss_obs_pred_q15(CtrlLoop *lp, float y, float u_prev, float u_k)
 499:ctrl_pend.c   **** {
 500:ctrl_pend.c   ****     float qs = lp->q_scale;
 501:ctrl_pend.c   **** 
