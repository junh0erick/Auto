 625:ctrl_pend.c   **** {
 626:ctrl_pend.c   ****     float qs = lp->q_scale;
 627:ctrl_pend.c   ****     q7_t xhat_q[2];
 628:ctrl_pend.c   ****     q31_t dot7;
 629:ctrl_pend.c   **** 
 630:ctrl_pend.c   ****     xhat_q[0] = flt_to_q7n(lp->xhat[0] / qs);
