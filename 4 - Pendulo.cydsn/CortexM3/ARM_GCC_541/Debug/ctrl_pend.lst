 242:ctrl_pend.c   **** /* ============================================================
 243:ctrl_pend.c   ****    SS helpers — F32 (patrón idéntico a Elia control_app.c)
 244:ctrl_pend.c   ****    arm_dot_prod_f32: dot product
 245:ctrl_pend.c   ****    arm_scale_f32:    v * escalar → destino
 246:ctrl_pend.c   ****    arm_add_f32:      suma elemento a elemento
 247:ctrl_pend.c   ****    ============================================================ */
 248:ctrl_pend.c   **** 
 249:ctrl_pend.c   **** /* ŷ = C·x + D·u */
 250:ctrl_pend.c   **** static float ss_yhat_f32(CtrlLoop *lp, const float x[2], float u)
 251:ctrl_pend.c   **** {
 252:ctrl_pend.c   ****     float out = 0.0f;
 253:ctrl_pend.c   ****     arm_dot_prod_f32((float32_t*)lp->C, (float32_t*)x, 2u, (float32_t*)&out);
 254:ctrl_pend.c   ****     return out + lp->D * u;
 255:ctrl_pend.c   **** }
 256:ctrl_pend.c   **** 
 257:ctrl_pend.c   **** /* z = A·x + B·u  (por fila, igual que Elia dot2_cmsis) */
 258:ctrl_pend.c   **** static void ss_predict_f32(CtrlLoop *lp, const float x[2], float u, float z[2])
 259:ctrl_pend.c   **** {
 260:ctrl_pend.c   ****     arm_dot_prod_f32((float32_t*)&lp->A[0], (float32_t*)x, 2u, (float32_t*)&z[0]);
 261:ctrl_pend.c   ****     z[0] += lp->B[0] * u;
 262:ctrl_pend.c   ****     arm_dot_prod_f32((float32_t*)&lp->A[2], (float32_t*)x, 2u, (float32_t*)&z[1]);
 263:ctrl_pend.c   ****     z[1] += lp->B[1] * u;
 264:ctrl_pend.c   **** }
 265:ctrl_pend.c   **** 
 266:ctrl_pend.c   **** /* u_cmd = −K·xhat + Kx*(vint o ref) */
 267:ctrl_pend.c   **** static float ss_u_cmd_f32(CtrlLoop *lp)
 268:ctrl_pend.c   **** {
 269:ctrl_pend.c   ****     float kx = 0.0f;
 270:ctrl_pend.c   ****     arm_dot_prod_f32((float32_t*)lp->K, (float32_t*)lp->xhat, 2u, (float32_t*)&kx);
 271:ctrl_pend.c   ****     float extra = mode_has_i(lp->mode) ? (lp->Kx * lp->vint)
 272:ctrl_pend.c   ****                                        : (lp->Kx * lp->ref);
 273:ctrl_pend.c   ****     return extra - kx;
 274:ctrl_pend.c   **** }
 275:ctrl_pend.c   **** 
 276:ctrl_pend.c   **** /* Observer predictor:
 277:ctrl_pend.c   ****    innov = y − ŷ(xhat, u_prev)
 278:ctrl_pend.c   ****    z = A·xhat + B·u_k
 279:ctrl_pend.c   ****    xhat ← z + L·innov                                         */
 280:ctrl_pend.c   **** static void ss_obs_pred_f32(CtrlLoop *lp, float y, float u_prev, float u_k)
 281:ctrl_pend.c   **** {
 282:ctrl_pend.c   ****     float innov = y - ss_yhat_f32(lp, lp->xhat, u_prev);
 283:ctrl_pend.c   ****     float z[2], Linv[2];
 284:ctrl_pend.c   ****     ss_predict_f32(lp, lp->xhat, u_k, z);
 285:ctrl_pend.c   ****     arm_scale_f32((float32_t*)lp->L, innov, (float32_t*)Linv, 2u);
 286:ctrl_pend.c   ****     arm_add_f32((float32_t*)z, (float32_t*)Linv, (float32_t*)lp->xhat, 2u);
 287:ctrl_pend.c   **** }
 288:ctrl_pend.c   **** 
 289:ctrl_pend.c   **** /* Observer actual — corrección: xhat ← zhat + L·innov       */
 290:ctrl_pend.c   **** static void ss_obs_act_correct_f32(CtrlLoop *lp, float y, float u_prev)
 291:ctrl_pend.c   **** {
 292:ctrl_pend.c   ****     float innov = y - ss_yhat_f32(lp, lp->zhat, u_prev);
 293:ctrl_pend.c   ****     float Linv[2];
 294:ctrl_pend.c   ****     arm_scale_f32((float32_t*)lp->L, innov, (float32_t*)Linv, 2u);
 295:ctrl_pend.c   ****     arm_add_f32((float32_t*)lp->zhat, (float32_t*)Linv, (float32_t*)lp->xhat, 2u);
 296:ctrl_pend.c   **** }
 297:ctrl_pend.c   **** 
 298:ctrl_pend.c   **** /* Observer actual — predicción: zhat ← A·xhat + B·u         */
ARM GAS  C:\Users\user\AppData\Local\Temp\ccvG3JZK.s 			page 11


 299:ctrl_pend.c   **** static void ss_obs_act_predict_f32(CtrlLoop *lp, float u_k)
 300:ctrl_pend.c   **** {
 301:ctrl_pend.c   ****     ss_predict_f32(lp, lp->xhat, u_k, lp->zhat);
 302:ctrl_pend.c   **** }
