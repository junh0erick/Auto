 271:ctrl_pend.c   **** /* ============================================================
 272:ctrl_pend.c   ****    SS helpers — F32 (patrón idéntico a Elia control_app.c)
 273:ctrl_pend.c   ****    arm_dot_prod_f32: dot product
 274:ctrl_pend.c   ****    arm_scale_f32:    v * escalar → destino
 275:ctrl_pend.c   ****    arm_add_f32:      suma elemento a elemento
 276:ctrl_pend.c   ****    ============================================================ */
 277:ctrl_pend.c   **** 
 278:ctrl_pend.c   **** /* ŷ = C·x + D·u */
 279:ctrl_pend.c   **** static float ss_yhat_f32(CtrlLoop *lp, const float x[2], float u)
 280:ctrl_pend.c   **** {
 281:ctrl_pend.c   ****     float out = 0.0f;
 282:ctrl_pend.c   ****     arm_dot_prod_f32((float32_t*)lp->C, (float32_t*)x, 2u, (float32_t*)&out);
 283:ctrl_pend.c   ****     return out + lp->D * u;
 284:ctrl_pend.c   **** }
 285:ctrl_pend.c   **** 
 286:ctrl_pend.c   **** /* z = A·x + B·u  (por fila, igual que Elia dot2_cmsis) */
 287:ctrl_pend.c   **** static void ss_predict_f32(CtrlLoop *lp, const float x[2], float u, float z[2])
 288:ctrl_pend.c   **** {
 289:ctrl_pend.c   ****     arm_dot_prod_f32((float32_t*)&lp->A[0], (float32_t*)x, 2u, (float32_t*)&z[0]);
 290:ctrl_pend.c   ****     z[0] += lp->B[0] * u;
 291:ctrl_pend.c   ****     arm_dot_prod_f32((float32_t*)&lp->A[2], (float32_t*)x, 2u, (float32_t*)&z[1]);
 292:ctrl_pend.c   ****     z[1] += lp->B[1] * u;
 293:ctrl_pend.c   **** }
 294:ctrl_pend.c   **** 
 295:ctrl_pend.c   **** /* u_cmd = −K·xhat + Kx*(vint o ref) */
 296:ctrl_pend.c   **** static float ss_u_cmd_f32(CtrlLoop *lp)
 297:ctrl_pend.c   **** {
 298:ctrl_pend.c   ****     float kx = 0.0f;
ARM GAS  C:\Users\user\AppData\Local\Temp\ccVZNIFl.s 			page 11


 299:ctrl_pend.c   ****     arm_dot_prod_f32((float32_t*)lp->K, (float32_t*)lp->xhat, 2u, (float32_t*)&kx);
 300:ctrl_pend.c   ****     float extra = mode_has_i(lp->mode) ? (lp->Kx * lp->vint)
 301:ctrl_pend.c   ****                                        : (lp->Kx * lp->ref);
 302:ctrl_pend.c   ****     return extra - kx;
 303:ctrl_pend.c   **** }
 304:ctrl_pend.c   **** 
 305:ctrl_pend.c   **** /* Observer predictor:
 306:ctrl_pend.c   ****    innov = y − ŷ(xhat, u_prev)
 307:ctrl_pend.c   ****    z = A·xhat + B·u_k
 308:ctrl_pend.c   ****    xhat ← z + L·innov                                         */
 309:ctrl_pend.c   **** static void ss_obs_pred_f32(CtrlLoop *lp, float y, float u_prev, float u_k)
 310:ctrl_pend.c   **** {
 311:ctrl_pend.c   ****     float innov = y - ss_yhat_f32(lp, lp->xhat, u_prev);
 312:ctrl_pend.c   ****     float z[2], Linv[2];
 313:ctrl_pend.c   ****     ss_predict_f32(lp, lp->xhat, u_k, z);
 314:ctrl_pend.c   ****     arm_scale_f32((float32_t*)lp->L, innov, (float32_t*)Linv, 2u);
 315:ctrl_pend.c   ****     arm_add_f32((float32_t*)z, (float32_t*)Linv, (float32_t*)lp->xhat, 2u);
 316:ctrl_pend.c   **** }
 317:ctrl_pend.c   **** 
 318:ctrl_pend.c   **** /* Observer actual — corrección: xhat ← zhat + L·innov       */
 319:ctrl_pend.c   **** static void ss_obs_act_correct_f32(CtrlLoop *lp, float y, float u_prev)
 320:ctrl_pend.c   **** {
 321:ctrl_pend.c   ****     float innov = y - ss_yhat_f32(lp, lp->zhat, u_prev);
 322:ctrl_pend.c   ****     float Linv[2];
 323:ctrl_pend.c   ****     arm_scale_f32((float32_t*)lp->L, innov, (float32_t*)Linv, 2u);
 324:ctrl_pend.c   ****     arm_add_f32((float32_t*)lp->zhat, (float32_t*)Linv, (float32_t*)lp->xhat, 2u);
 325:ctrl_pend.c   **** }
 326:ctrl_pend.c   **** 
 327:ctrl_pend.c   **** /* Observer actual — predicción: zhat ← A·xhat + B·u         */
 328:ctrl_pend.c   **** static void ss_obs_act_predict_f32(CtrlLoop *lp, float u_k)
 329:ctrl_pend.c   **** {
 330:ctrl_pend.c   ****     ss_predict_f32(lp, lp->xhat, u_k, lp->zhat);
 331:ctrl_pend.c   **** }
 332:ctrl_pend.c   **** 
