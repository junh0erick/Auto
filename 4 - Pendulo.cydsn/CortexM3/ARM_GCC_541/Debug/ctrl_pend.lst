 211:ctrl_pend.c   ****     if (v > (q63_t)0x7FFFFFFF)  return (q31_t)0x7FFFFFFF;
 212:ctrl_pend.c   ****     if (v < (q63_t)0xFFFFFFFF80000000LL) return (q31_t)0x80000000;
 213:ctrl_pend.c   ****     return (q31_t)v;
 214:ctrl_pend.c   **** }
 215:ctrl_pend.c   **** static inline q15_t qsat15(q31_t v) {
 216:ctrl_pend.c   ****     if (v >  0x7FFF) return (q15_t)0x7FFF;
 217:ctrl_pend.c   ****     if (v < (q31_t)0xFFFF8000) return (q15_t)0x8000;
