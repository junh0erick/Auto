 603:ctrl_pend.c   **** {
 604:ctrl_pend.c   ****     float qs = lp->q_scale;
 605:ctrl_pend.c   ****     q7_t xq[2], Buq[2];
 606:ctrl_pend.c   ****     q31_t dot7;
 607:ctrl_pend.c   **** 
