   1:ctrl_pend.c   **** /* ============================================================
   2:ctrl_pend.c   ****    ctrl_pend.c — Two-plant on-PSoC controller  v6.3
   3:ctrl_pend.c   ****    CMSIS-DSP: f32 + Q31 / Q15 / Q7 paths.
   4:ctrl_pend.c   **** 
   5:ctrl_pend.c   ****    Tipo numérico seleccionable (g_num_type) para el observer SS:
   6:ctrl_pend.c   ****      F32  → arm_dot_prod/scale/add_f32      (siempre preciso)
   7:ctrl_pend.c   ****      Q31  → arm_dot_prod/scale/add_q31      (entero, eficiente CM3)
   8:ctrl_pend.c   ****      Q15  → arm_dot_prod/scale/add_q15      (SIMD, muy eficiente CM3)
   9:ctrl_pend.c   ****      Q7   → arm_dot_prod/scale/add_q7       (baja precisión)
  10:ctrl_pend.c   ****      F64/F16 → fallback a F32 en PSoC
  11:ctrl_pend.c   **** 
  12:ctrl_pend.c   ****    Normalización para paths Q:
  13:ctrl_pend.c   ****      q_scale (c[16]): todas las señales físicas (y, xhat, u, ref, vint)
  14:ctrl_pend.c   ****      se dividen por q_scale antes de convertir a Q.
  15:ctrl_pend.c   ****      Los coeficientes (A,B,C,D,K,L,Kx) se almacenan PRE-CONVERTIDOS a Q
  16:ctrl_pend.c   ****      SIN normalizar por q_scale (sus valores ya deben ser |coef| < 1).
  17:ctrl_pend.c   ****      NOTA: si |K[i]|, |L[i]| > 1, la conversión a Q satura — normal para
  18:ctrl_pend.c   ****      sistemas físicos con ganancias grandes. El usuario ajusta q_scale y
  19:ctrl_pend.c   ****      diseña el controlador normalizado para usar paths Q con precisión.
  20:ctrl_pend.c   **** 
  21:ctrl_pend.c   ****    Integrador siempre en float (acumula suma de errores sin Ts —
  22:ctrl_pend.c   ****    convención Elia). La ley de control final se hace en float tras
  23:ctrl_pend.c   ****    recuperar xhat del path Q.
  24:ctrl_pend.c   **** 
  25:ctrl_pend.c   ****    TF mode: usa siempre F32 (DF2T scalar, Q no aporta para 6 coef).
  26:ctrl_pend.c   **** 
  27:ctrl_pend.c   ****    Basado en Elia control_app.c (helicóptero FinalV1.8):
  28:ctrl_pend.c   ****      - TF DF2T orden 5 idéntico
  29:ctrl_pend.c   ****      - SS predictor/actual idéntico (innov, z=Ax+Bu, xhat=z+Linv)
ARM GAS  C:\Users\user\AppData\Local\Temp\cc6TIdBD.s 			page 2


  30:ctrl_pend.c   ****      - u_out tracking (saturado) idéntico a g_u_out de Elia
  31:ctrl_pend.c   ****      - vint += e (sin Ts) idéntico
  32:ctrl_pend.c   **** 
  33:ctrl_pend.c   ****    Build: ARM_MATH_CM3 en Preprocessor Defines.
  34:ctrl_pend.c   ****    ============================================================ */
  35:ctrl_pend.c   **** 
  36:ctrl_pend.c   **** #define ARM_MATH_CM3    /* PSoC 5LP = Cortex-M3, sin FPU */
  37:ctrl_pend.c   **** #include "arm_math.h"
  38:ctrl_pend.c   **** 
  39:ctrl_pend.c   **** #include "ctrl_pend.h"
  40:ctrl_pend.c   **** #include "uartp_pend.h"
  41:ctrl_pend.c   **** #include "pendulo.h"
  42:ctrl_pend.c   **** #include "motor.h"
  43:ctrl_pend.c   **** #include <string.h>
  44:ctrl_pend.c   **** 
  45:ctrl_pend.c   **** /* Helper: límite físico efectivo para el lazo inner según modo de salida.
  46:ctrl_pend.c   ****    Cuando la salida del controlador es voltaje (bit1 de g_ref_in_volts), el
  47:ctrl_pend.c   ****    tope es ±MOTOR_V_MAX; en modo PWM directo, ±MOTOR_MAX. Tightens (nunca
  48:ctrl_pend.c   ****    amplía) el sat_min/max definido por el usuario en MATLAB. */
  49:ctrl_pend.c   **** static inline void inner_phys_limits(float *lo, float *hi)
  50:ctrl_pend.c   **** {
  51:ctrl_pend.c   ****     float pmin, pmax;
  52:ctrl_pend.c   ****     if (g_ref_in_volts & 0x02u) {
  53:ctrl_pend.c   ****         pmax =  MOTOR_V_MAX;  pmin = -MOTOR_V_MAX;
  54:ctrl_pend.c   ****     } else {
  55:ctrl_pend.c   ****         pmax =  (float)MOTOR_MAX;  pmin = (float)MOTOR_MIN;
  56:ctrl_pend.c   ****     }
  57:ctrl_pend.c   ****     if (*hi > pmax) *hi = pmax;
  58:ctrl_pend.c   ****     if (*lo < pmin) *lo = pmin;
  59:ctrl_pend.c   **** }
  60:ctrl_pend.c   **** 
  61:ctrl_pend.c   **** /* ============================================================
  62:ctrl_pend.c   ****    Constantes físicas
  63:ctrl_pend.c   ****    ============================================================ */
  64:ctrl_pend.c   **** #define PI_F            3.14159265f
  65:ctrl_pend.c   **** #define MOTOR_CPR_F     1040.0f     /* 4 × 260 PPR (QuadDec x4) */
  66:ctrl_pend.c   **** #define PENDULO_CPR_F   10000.0f
  67:ctrl_pend.c   **** #define PWM_MAX_F       1264.0f
  68:ctrl_pend.c   **** #define PWM_MIN_F      (-1264.0f)
  69:ctrl_pend.c   **** 
  70:ctrl_pend.c   **** /* Filtro Åström de primer orden: y_f = α·y_f_prev + (1−α)·y_raw.
  71:ctrl_pend.c   ****    DC gain = 1; polo discreto α = e^(-2π·fn·Ts) ∈ (0,1).
  72:ctrl_pend.c   ****    - MOT:  fn = 50 Hz → α = e^(-π/2)  ≈ 0.2079  (sobre y1, velocidad motor)
  73:ctrl_pend.c   ****    - PEND: fn = 10 Hz → α = e^(-π/10) ≈ 0.7304  (sobre y2, ángulo péndulo) */
  74:ctrl_pend.c   **** #define ALPHA_ASTROM_MOT     0.207879576350762f
  75:ctrl_pend.c   **** #define ALPHA_ASTROM_PEND    0.730402691048646f
  76:ctrl_pend.c   **** 
  77:ctrl_pend.c   **** /* ============================================================
  78:ctrl_pend.c   ****    Struct de estado por planta
  79:ctrl_pend.c   ****    ============================================================ */
  80:ctrl_pend.c   **** typedef struct {
  81:ctrl_pend.c   ****     uint8  mode;            /* CTRL_MODE_* */
  82:ctrl_pend.c   **** 
  83:ctrl_pend.c   ****     /* TF – Direct Form II Transposed, hasta orden 5 */
  84:ctrl_pend.c   ****     float  tf_b[6];
  85:ctrl_pend.c   ****     float  tf_a[6];         /* a[0] siempre 1 tras normalización */
  86:ctrl_pend.c   ****     float  tf_w[5];         /* estados de retardo */
