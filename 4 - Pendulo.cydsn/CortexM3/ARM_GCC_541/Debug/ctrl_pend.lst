 457:ctrl_pend.c   **** static void ss_predict_q15(CtrlLoop *lp, const float x[2], float u, float z[2])
 458:ctrl_pend.c   **** {
 459:ctrl_pend.c   ****     float qs = lp->q_scale;
 460:ctrl_pend.c   ****     q15_t xq[2], Buq[2];
 461:ctrl_pend.c   ****     q63_t dot;
 462:ctrl_pend.c   **** 
 463:ctrl_pend.c   ****     xq[0] = flt_to_q15n(x[0] / qs);
 464:ctrl_pend.c   ****     xq[1] = flt_to_q15n(x[1] / qs);
 465:ctrl_pend.c   ****     q15_t uq = flt_to_q15n(u / qs);
 466:ctrl_pend.c   **** 
 467:ctrl_pend.c   ****     /* B·u: arm_scale_q15 escala el vector B por escalar u */
ARM GAS  C:\Users\user\AppData\Local\Temp\ccvG3JZK.s 			page 44


 468:ctrl_pend.c   ****     arm_scale_q15(lp->qB15, uq, 0, Buq, 2u);
