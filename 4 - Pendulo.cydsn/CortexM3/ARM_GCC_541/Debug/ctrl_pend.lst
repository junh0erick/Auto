  60:ctrl_pend.c   ****     float  tf_b[6];
  61:ctrl_pend.c   ****     float  tf_a[6];         /* a[0] siempre 1 tras normalización */
  62:ctrl_pend.c   ****     float  tf_w[5];         /* estados de retardo */
  63:ctrl_pend.c   **** 
  64:ctrl_pend.c   ****     /* SS – 2 estados, float */
  65:ctrl_pend.c   ****     float  A[4];            /* 2×2 row-major: [A11 A12 A21 A22] */
  66:ctrl_pend.c   ****     float  B[2];            /* 2×1 */
  67:ctrl_pend.c   ****     float  C[2];            /* 1×2 */
  68:ctrl_pend.c   ****     float  D;
