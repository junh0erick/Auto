 632:ctrl_pend.c   **** 
 633:ctrl_pend.c   ****     arm_dot_prod_q7(lp->qK7, xhat_q, 2u, &dot7);
 634:ctrl_pend.c   ****     q7_t kx = qsat7((q15_t)(dot7 >> 7));
 635:ctrl_pend.c   **** 
 636:ctrl_pend.c   ****     float extra_f = mode_has_i(lp->mode) ? (lp->Kx * lp->vint)
 637:ctrl_pend.c   ****                                          : (lp->Kx * lp->ref);
 638:ctrl_pend.c   ****     q7_t extra_q = flt_to_q7n(extra_f / qs);
 639:ctrl_pend.c   **** 
 640:ctrl_pend.c   ****     return q7_to_flt(qsat7((q15_t)extra_q - kx)) * qs;
 641:ctrl_pend.c   **** }
