 486:ctrl_pend.c   **** static void ss_predict_q15(CtrlLoop *lp, const float x[2], float u, float z[2])
 487:ctrl_pend.c   **** {
 488:ctrl_pend.c   ****     float qs = lp->q_scale;
 489:ctrl_pend.c   ****     q15_t xq[2], Buq[2];
 490:ctrl_pend.c   ****     q63_t dot;
 491:ctrl_pend.c   **** 
 492:ctrl_pend.c   ****     xq[0] = flt_to_q15n(x[0] / qs);
 493:ctrl_pend.c   ****     xq[1] = flt_to_q15n(x[1] / qs);
 494:ctrl_pend.c   ****     q15_t uq = flt_to_q15n(u / qs);
 495:ctrl_pend.c   **** 
 496:ctrl_pend.c   ****     /* B·u: arm_scale_q15 escala el vector B por escalar u */
 497:ctrl_pend.c   ****     arm_scale_q15(lp->qB15, uq, 0, Buq, 2u);
 498:ctrl_pend.c   **** 
 499:ctrl_pend.c   ****     arm_dot_prod_q15(&lp->qA15[0], xq, 2u, &dot);
 500:ctrl_pend.c   ****     q15_t Ax0 = qsat15((q31_t)(dot >> 15));
 501:ctrl_pend.c   ****     z[0] = q15_to_flt(qsat15((q31_t)Ax0 + Buq[0])) * qs;
 502:ctrl_pend.c   **** 
 503:ctrl_pend.c   ****     arm_dot_prod_q15(&lp->qA15[2], xq, 2u, &dot);
 504:ctrl_pend.c   ****     q15_t Ax1 = qsat15((q31_t)(dot >> 15));
 505:ctrl_pend.c   ****     z[1] = q15_to_flt(qsat15((q31_t)Ax1 + Buq[1])) * qs;
 506:ctrl_pend.c   **** }
 507:ctrl_pend.c   **** 
 508:ctrl_pend.c   **** static float ss_u_cmd_q15(CtrlLoop *lp)
 509:ctrl_pend.c   **** {
 510:ctrl_pend.c   ****     float qs = lp->q_scale;
 511:ctrl_pend.c   ****     q15_t xhat_q[2];
 512:ctrl_pend.c   ****     q63_t dot;
 513:ctrl_pend.c   **** 
 514:ctrl_pend.c   ****     xhat_q[0] = flt_to_q15n(lp->xhat[0] / qs);
 515:ctrl_pend.c   ****     xhat_q[1] = flt_to_q15n(lp->xhat[1] / qs);
 516:ctrl_pend.c   **** 
 517:ctrl_pend.c   ****     arm_dot_prod_q15(lp->qK15, xhat_q, 2u, &dot);
 518:ctrl_pend.c   ****     q15_t kx = qsat15((q31_t)(dot >> 15));
 519:ctrl_pend.c   **** 
 520:ctrl_pend.c   ****     float extra_f = mode_has_i(lp->mode) ? (lp->Kx * lp->vint)
 521:ctrl_pend.c   ****                                          : (lp->Kx * lp->ref);
 522:ctrl_pend.c   ****     q15_t extra_q = flt_to_q15n(extra_f / qs);
 523:ctrl_pend.c   **** 
 524:ctrl_pend.c   ****     return q15_to_flt(qsat15((q31_t)extra_q - kx)) * qs;
ARM GAS  C:\Users\user\AppData\Local\Temp\cc6TIdBD.s 			page 45


 525:ctrl_pend.c   **** }
 526:ctrl_pend.c   **** 
 527:ctrl_pend.c   **** static void ss_obs_pred_q15(CtrlLoop *lp, float y, float u_prev, float u_k)
 528:ctrl_pend.c   **** {
 529:ctrl_pend.c   ****     float qs = lp->q_scale;
 530:ctrl_pend.c   **** 
 531:ctrl_pend.c   ****     float innov = y - ss_yhat_q15(lp, lp->xhat, u_prev);
 532:ctrl_pend.c   ****     q15_t innov_q = flt_to_q15n(innov / qs);
 533:ctrl_pend.c   **** 
 534:ctrl_pend.c   ****     float z[2];
 535:ctrl_pend.c   ****     ss_predict_q15(lp, lp->xhat, u_k, z);
 536:ctrl_pend.c   **** 
 537:ctrl_pend.c   ****     q15_t Linv[2];
 538:ctrl_pend.c   ****     arm_scale_q15(lp->qL15, innov_q, 0, Linv, 2u);
 539:ctrl_pend.c   **** 
 540:ctrl_pend.c   ****     q15_t zq[2];
 541:ctrl_pend.c   ****     zq[0] = flt_to_q15n(z[0] / qs);
 542:ctrl_pend.c   ****     zq[1] = flt_to_q15n(z[1] / qs);
 543:ctrl_pend.c   ****     q15_t xhat_q[2];
 544:ctrl_pend.c   ****     arm_add_q15(zq, Linv, xhat_q, 2u);
 545:ctrl_pend.c   **** 
 546:ctrl_pend.c   ****     lp->xhat[0] = q15_to_flt(xhat_q[0]) * qs;
 547:ctrl_pend.c   ****     lp->xhat[1] = q15_to_flt(xhat_q[1]) * qs;
 548:ctrl_pend.c   **** }
