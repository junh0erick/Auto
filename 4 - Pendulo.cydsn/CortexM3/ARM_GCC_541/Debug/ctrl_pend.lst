 503:ctrl_pend.c   ****     q15_t innov_q = flt_to_q15n(innov / qs);
 504:ctrl_pend.c   **** 
 505:ctrl_pend.c   ****     float z[2];
 506:ctrl_pend.c   ****     ss_predict_q15(lp, lp->xhat, u_k, z);
 507:ctrl_pend.c   **** 
 508:ctrl_pend.c   ****     q15_t Linv[2];
 509:ctrl_pend.c   ****     arm_scale_q15(lp->qL15, innov_q, 0, Linv, 2u);
 510:ctrl_pend.c   **** 
 511:ctrl_pend.c   ****     q15_t zq[2];
 512:ctrl_pend.c   ****     zq[0] = flt_to_q15n(z[0] / qs);
 513:ctrl_pend.c   ****     zq[1] = flt_to_q15n(z[1] / qs);
 514:ctrl_pend.c   ****     q15_t xhat_q[2];
 515:ctrl_pend.c   ****     arm_add_q15(zq, Linv, xhat_q, 2u);
 516:ctrl_pend.c   **** 
 517:ctrl_pend.c   ****     lp->xhat[0] = q15_to_flt(xhat_q[0]) * qs;
 518:ctrl_pend.c   ****     lp->xhat[1] = q15_to_flt(xhat_q[1]) * qs;
 519:ctrl_pend.c   **** }
