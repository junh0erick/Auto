 170:ctrl_pend.c   **** /* ============================================================
 171:ctrl_pend.c   ****    Q-format inline conversions
 172:ctrl_pend.c   ****    Convención: todos los valores representados como fracción de
 173:ctrl_pend.c   ****    q_scale, es decir: q_val = physical_val / q_scale ∈ [-1, 1).
 174:ctrl_pend.c   ****    ============================================================ */
 175:ctrl_pend.c   **** 
 176:ctrl_pend.c   **** /* Float normalizado [-1,1) → Q31 */
 177:ctrl_pend.c   **** static inline q31_t flt_to_q31n(float v) {
 178:ctrl_pend.c   ****     if (v >= 1.0f)  return  (q31_t)0x7FFFFFFF;
 179:ctrl_pend.c   ****     if (v < -1.0f)  return  (q31_t)0x80000000;
 180:ctrl_pend.c   ****     return (q31_t)(v * 2147483648.0f);
 181:ctrl_pend.c   **** }
 182:ctrl_pend.c   **** /* Q31 → float normalizado [-1,1) */
 183:ctrl_pend.c   **** static inline float q31_to_flt(q31_t v) {
 184:ctrl_pend.c   ****     return (float)v * (1.0f / 2147483648.0f);
 185:ctrl_pend.c   **** }
 186:ctrl_pend.c   **** 
 187:ctrl_pend.c   **** /* Float normalizado [-1,1) → Q15 */
 188:ctrl_pend.c   **** static inline q15_t flt_to_q15n(float v) {
 189:ctrl_pend.c   ****     if (v >= 1.0f)  return  (q15_t)0x7FFF;
 190:ctrl_pend.c   ****     if (v < -1.0f)  return  (q15_t)0x8000;
 191:ctrl_pend.c   ****     return (q15_t)(v * 32768.0f);
 192:ctrl_pend.c   **** }
 193:ctrl_pend.c   **** /* Q15 → float normalizado */
 194:ctrl_pend.c   **** static inline float q15_to_flt(q15_t v) {
 195:ctrl_pend.c   ****     return (float)v * (1.0f / 32768.0f);
 196:ctrl_pend.c   **** }
 197:ctrl_pend.c   **** 
 198:ctrl_pend.c   **** /* Float normalizado [-1,1) → Q7 */
 199:ctrl_pend.c   **** static inline q7_t flt_to_q7n(float v) {
 200:ctrl_pend.c   ****     if (v >= 1.0f)  return  (q7_t)0x7F;
 201:ctrl_pend.c   ****     if (v < -1.0f)  return  (q7_t)0x80;
 202:ctrl_pend.c   ****     return (q7_t)(v * 128.0f);
 203:ctrl_pend.c   **** }
 204:ctrl_pend.c   **** /* Q7 → float normalizado */
 205:ctrl_pend.c   **** static inline float q7_to_flt(q7_t v) {
 206:ctrl_pend.c   ****     return (float)v * (1.0f / 128.0f);
 207:ctrl_pend.c   **** }
 208:ctrl_pend.c   **** 
 209:ctrl_pend.c   **** /* Saturating add helpers para escalares Q */
ARM GAS  C:\Users\user\AppData\Local\Temp\ccvG3JZK.s 			page 7


