 199:ctrl_pend.c   **** /* ============================================================
 200:ctrl_pend.c   ****    Q-format inline conversions
 201:ctrl_pend.c   ****    Convención: todos los valores representados como fracción de
 202:ctrl_pend.c   ****    q_scale, es decir: q_val = physical_val / q_scale ∈ [-1, 1).
 203:ctrl_pend.c   ****    ============================================================ */
 204:ctrl_pend.c   **** 
 205:ctrl_pend.c   **** /* Float normalizado [-1,1) → Q31 */
 206:ctrl_pend.c   **** static inline q31_t flt_to_q31n(float v) {
 207:ctrl_pend.c   ****     if (v >= 1.0f)  return  (q31_t)0x7FFFFFFF;
 208:ctrl_pend.c   ****     if (v < -1.0f)  return  (q31_t)0x80000000;
 209:ctrl_pend.c   ****     return (q31_t)(v * 2147483648.0f);
ARM GAS  C:\Users\user\AppData\Local\Temp\ccVZNIFl.s 			page 7


 210:ctrl_pend.c   **** }
 211:ctrl_pend.c   **** /* Q31 → float normalizado [-1,1) */
 212:ctrl_pend.c   **** static inline float q31_to_flt(q31_t v) {
 213:ctrl_pend.c   ****     return (float)v * (1.0f / 2147483648.0f);
 214:ctrl_pend.c   **** }
 215:ctrl_pend.c   **** 
 216:ctrl_pend.c   **** /* Float normalizado [-1,1) → Q15 */
 217:ctrl_pend.c   **** static inline q15_t flt_to_q15n(float v) {
 218:ctrl_pend.c   ****     if (v >= 1.0f)  return  (q15_t)0x7FFF;
 219:ctrl_pend.c   ****     if (v < -1.0f)  return  (q15_t)0x8000;
 220:ctrl_pend.c   ****     return (q15_t)(v * 32768.0f);
 221:ctrl_pend.c   **** }
 222:ctrl_pend.c   **** /* Q15 → float normalizado */
 223:ctrl_pend.c   **** static inline float q15_to_flt(q15_t v) {
 224:ctrl_pend.c   ****     return (float)v * (1.0f / 32768.0f);
 225:ctrl_pend.c   **** }
 226:ctrl_pend.c   **** 
 227:ctrl_pend.c   **** /* Float normalizado [-1,1) → Q7 */
 228:ctrl_pend.c   **** static inline q7_t flt_to_q7n(float v) {
 229:ctrl_pend.c   ****     if (v >= 1.0f)  return  (q7_t)0x7F;
 230:ctrl_pend.c   ****     if (v < -1.0f)  return  (q7_t)0x80;
 231:ctrl_pend.c   ****     return (q7_t)(v * 128.0f);
 232:ctrl_pend.c   **** }
 233:ctrl_pend.c   **** /* Q7 → float normalizado */
 234:ctrl_pend.c   **** static inline float q7_to_flt(q7_t v) {
 235:ctrl_pend.c   ****     return (float)v * (1.0f / 128.0f);
 236:ctrl_pend.c   **** }
 237:ctrl_pend.c   **** 
 238:ctrl_pend.c   **** /* Saturating add helpers para escalares Q */
 239:ctrl_pend.c   **** static inline q31_t qsat31(q63_t v) {
 240:ctrl_pend.c   ****     if (v > (q63_t)0x7FFFFFFF)  return (q31_t)0x7FFFFFFF;
 241:ctrl_pend.c   ****     if (v < (q63_t)0xFFFFFFFF80000000LL) return (q31_t)0x80000000;
 242:ctrl_pend.c   ****     return (q31_t)v;
 243:ctrl_pend.c   **** }
 244:ctrl_pend.c   **** static inline q15_t qsat15(q31_t v) {
 245:ctrl_pend.c   ****     if (v >  0x7FFF) return (q15_t)0x7FFF;
