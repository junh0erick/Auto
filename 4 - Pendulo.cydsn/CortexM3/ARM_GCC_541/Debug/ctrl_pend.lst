 470:ctrl_pend.c   ****     arm_dot_prod_q15(&lp->qA15[0], xq, 2u, &dot);
 471:ctrl_pend.c   ****     q15_t Ax0 = qsat15((q31_t)(dot >> 15));
 472:ctrl_pend.c   ****     z[0] = q15_to_flt(qsat15((q31_t)Ax0 + Buq[0])) * qs;
 473:ctrl_pend.c   **** 
