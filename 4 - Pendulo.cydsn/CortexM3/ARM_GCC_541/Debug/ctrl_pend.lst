 595:ctrl_pend.c   **** static float ss_u_cmd_q7(CtrlLoop *lp)
 596:ctrl_pend.c   **** {
 597:ctrl_pend.c   ****     float qs = lp->q_scale;
 598:ctrl_pend.c   ****     q7_t xhat_q[2];
 599:ctrl_pend.c   ****     q31_t dot7;
 600:ctrl_pend.c   **** 
 601:ctrl_pend.c   ****     xhat_q[0] = flt_to_q7n(lp->xhat[0] / qs);
 602:ctrl_pend.c   ****     xhat_q[1] = flt_to_q7n(lp->xhat[1] / qs);
 603:ctrl_pend.c   **** 
 604:ctrl_pend.c   ****     arm_dot_prod_q7(lp->qK7, xhat_q, 2u, &dot7);
 605:ctrl_pend.c   ****     q7_t kx = qsat7((q15_t)(dot7 >> 7));
 606:ctrl_pend.c   **** 
 607:ctrl_pend.c   ****     float extra_f = mode_has_i(lp->mode) ? (lp->Kx * lp->vint)
 608:ctrl_pend.c   ****                                          : (lp->Kx * lp->ref);
 609:ctrl_pend.c   ****     q7_t extra_q = flt_to_q7n(extra_f / qs);
 610:ctrl_pend.c   **** 
 611:ctrl_pend.c   ****     return q7_to_flt(qsat7((q15_t)extra_q - kx)) * qs;
 612:ctrl_pend.c   **** }
