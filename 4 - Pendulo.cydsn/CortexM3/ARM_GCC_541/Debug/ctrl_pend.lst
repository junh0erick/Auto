 334:ctrl_pend.c   **** static void ss_predict_q31(CtrlLoop *lp, const float x[2], float u, float z[2])
 335:ctrl_pend.c   **** {
 336:ctrl_pend.c   ****     float qs = lp->q_scale;
 337:ctrl_pend.c   ****     q31_t xq[2], Buq[2];
 338:ctrl_pend.c   ****     q63_t dot;
 339:ctrl_pend.c   **** 
 340:ctrl_pend.c   ****     xq[0] = flt_to_q31n(x[0] / qs);
 341:ctrl_pend.c   ****     xq[1] = flt_to_q31n(x[1] / qs);
 342:ctrl_pend.c   ****     q31_t uq = flt_to_q31n(u / qs);
 343:ctrl_pend.c   **** 
 344:ctrl_pend.c   ****     /* B·u: arm_scale_q31 escala el vector B por el escalar u.
 345:ctrl_pend.c   ****        Resultado: Buq[i] = (B_q31[i] × uq) >> 31 → Q31 */
 346:ctrl_pend.c   ****     arm_scale_q31(lp->qB31, uq, 0, Buq, 2u);
 347:ctrl_pend.c   **** 
 348:ctrl_pend.c   ****     /* Fila 0: A[0..1]·x */
 349:ctrl_pend.c   ****     arm_dot_prod_q31(&lp->qA31[0], xq, 2u, &dot);
 350:ctrl_pend.c   ****     q31_t Ax0 = (q31_t)(dot >> 17);
 351:ctrl_pend.c   ****     z[0] = q31_to_flt(qsat31((q63_t)Ax0 + Buq[0])) * qs;
 352:ctrl_pend.c   **** 
 353:ctrl_pend.c   ****     /* Fila 1: A[2..3]·x */
 354:ctrl_pend.c   ****     arm_dot_prod_q31(&lp->qA31[2], xq, 2u, &dot);
 355:ctrl_pend.c   ****     q31_t Ax1 = (q31_t)(dot >> 17);
 356:ctrl_pend.c   ****     z[1] = q31_to_flt(qsat31((q63_t)Ax1 + Buq[1])) * qs;
 357:ctrl_pend.c   **** }
 358:ctrl_pend.c   **** 
 359:ctrl_pend.c   **** static float ss_u_cmd_q31(CtrlLoop *lp)
 360:ctrl_pend.c   **** {
 361:ctrl_pend.c   ****     float qs = lp->q_scale;
 362:ctrl_pend.c   ****     q31_t xhat_q[2];
 363:ctrl_pend.c   ****     q63_t dot;
 364:ctrl_pend.c   **** 
 365:ctrl_pend.c   ****     xhat_q[0] = flt_to_q31n(lp->xhat[0] / qs);
 366:ctrl_pend.c   ****     xhat_q[1] = flt_to_q31n(lp->xhat[1] / qs);
 367:ctrl_pend.c   **** 
 368:ctrl_pend.c   ****     arm_dot_prod_q31(lp->qK31, xhat_q, 2u, &dot);
 369:ctrl_pend.c   ****     q31_t kx = (q31_t)(dot >> 17);
 370:ctrl_pend.c   **** 
 371:ctrl_pend.c   ****     /* extra = Kx * vint_or_ref — calculado en float, luego normalizado */
 372:ctrl_pend.c   ****     float extra_f = mode_has_i(lp->mode) ? (lp->Kx * lp->vint)
 373:ctrl_pend.c   ****                                          : (lp->Kx * lp->ref);
 374:ctrl_pend.c   ****     q31_t extra_q = flt_to_q31n(extra_f / qs);
 375:ctrl_pend.c   **** 
 376:ctrl_pend.c   ****     return q31_to_flt(qsat31((q63_t)extra_q - kx)) * qs;
ARM GAS  C:\Users\user\AppData\Local\Temp\cctbbNEP.s 			page 17


 377:ctrl_pend.c   **** }
 378:ctrl_pend.c   **** 
 379:ctrl_pend.c   **** static void ss_obs_pred_q31(CtrlLoop *lp, float y, float u_prev, float u_k)
 380:ctrl_pend.c   **** {
 381:ctrl_pend.c   ****     float qs = lp->q_scale;
 382:ctrl_pend.c   **** 
 383:ctrl_pend.c   ****     /* innov = y - ŷ(xhat, u_prev) */
 384:ctrl_pend.c   ****     float innov = y - ss_yhat_q31(lp, lp->xhat, u_prev);
 385:ctrl_pend.c   ****     q31_t innov_q = flt_to_q31n(innov / qs);
 386:ctrl_pend.c   **** 
 387:ctrl_pend.c   ****     /* z = A·xhat + B·u_k (resultado en float) */
 388:ctrl_pend.c   ****     float z[2];
 389:ctrl_pend.c   ****     ss_predict_q31(lp, lp->xhat, u_k, z);
 390:ctrl_pend.c   **** 
 391:ctrl_pend.c   ****     /* Linv = L × innov: arm_scale_q31(L_q, innov_q, shift=0, Linv, 2) */
 392:ctrl_pend.c   ****     q31_t Linv[2];
 393:ctrl_pend.c   ****     arm_scale_q31(lp->qL31, innov_q, 0, Linv, 2u);
 394:ctrl_pend.c   **** 
 395:ctrl_pend.c   ****     /* xhat = z + Linv (suma Q31 saturada) */
 396:ctrl_pend.c   ****     q31_t zq[2];
 397:ctrl_pend.c   ****     zq[0] = flt_to_q31n(z[0] / qs);
 398:ctrl_pend.c   ****     zq[1] = flt_to_q31n(z[1] / qs);
 399:ctrl_pend.c   ****     q31_t xhat_q[2];
 400:ctrl_pend.c   ****     arm_add_q31(zq, Linv, xhat_q, 2u);
 401:ctrl_pend.c   **** 
 402:ctrl_pend.c   ****     lp->xhat[0] = q31_to_flt(xhat_q[0]) * qs;
 403:ctrl_pend.c   ****     lp->xhat[1] = q31_to_flt(xhat_q[1]) * qs;
 404:ctrl_pend.c   **** }
