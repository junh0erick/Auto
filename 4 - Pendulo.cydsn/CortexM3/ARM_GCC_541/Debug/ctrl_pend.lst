  87:ctrl_pend.c   **** 
  88:ctrl_pend.c   ****     /* SS – 2 estados, float */
  89:ctrl_pend.c   ****     float  A[4];            /* 2×2 row-major: [A11 A12 A21 A22] */
  90:ctrl_pend.c   ****     float  B[2];            /* 2×1 */
  91:ctrl_pend.c   ****     float  C[2];            /* 1×2 */
  92:ctrl_pend.c   ****     float  D;
  93:ctrl_pend.c   ****     float  L[2];            /* ganancia de observador */
  94:ctrl_pend.c   ****     float  K[2];            /* ganancia de realimentación */
  95:ctrl_pend.c   ****     float  Kx;              /* Nbar (sin integrador) o Ki (con integrador) */
  96:ctrl_pend.c   **** 
  97:ctrl_pend.c   ****     /* SS – estados del observador (float, siempre) */
  98:ctrl_pend.c   ****     float  xhat[2];         /* estimado posterior */
  99:ctrl_pend.c   ****     float  zhat[2];         /* estimado prior (observer actual) */
 100:ctrl_pend.c   ****     float  vint;            /* acumulador integral (float, sin Ts) */
 101:ctrl_pend.c   **** 
 102:ctrl_pend.c   ****     float  ref;             /* setpoint actual */
 103:ctrl_pend.c   ****     float  Nbar;            /* feedforward: u_total = C(z)*(ref-y) + Nbar*ref  (TF mode) */
 104:ctrl_pend.c   ****     float  u_out;           /* salida anterior saturada (para observer) */
 105:ctrl_pend.c   **** 
 106:ctrl_pend.c   ****     /* Decimación (solo outer, planta 1) */
 107:ctrl_pend.c   ****     uint16 N;
 108:ctrl_pend.c   ****     uint16 cnt;
 109:ctrl_pend.c   **** 
 110:ctrl_pend.c   ****     /* Normalización para Q-format (c[16], default 1.0f).
 111:ctrl_pend.c   ****        Señales: x_q = float_to_q(x / q_scale).
 112:ctrl_pend.c   ****        Coeficientes: almacenados sin dividir por q_scale. */
 113:ctrl_pend.c   ****     float  q_scale;
 114:ctrl_pend.c   **** 
 115:ctrl_pend.c   ****     /* Pre-convertidos Q31 (SS mode, arm_float_to_q31) */
 116:ctrl_pend.c   ****     q31_t  qA31[4];
 117:ctrl_pend.c   ****     q31_t  qB31[2];
 118:ctrl_pend.c   ****     q31_t  qC31[2];
 119:ctrl_pend.c   ****     q31_t  qK31[2];
 120:ctrl_pend.c   ****     q31_t  qL31[2];
 121:ctrl_pend.c   ****     q31_t  qD31;
 122:ctrl_pend.c   ****     q31_t  qKx31;
 123:ctrl_pend.c   **** 
 124:ctrl_pend.c   ****     /* Pre-convertidos Q15 */
 125:ctrl_pend.c   ****     q15_t  qA15[4];
 126:ctrl_pend.c   ****     q15_t  qB15[2];
 127:ctrl_pend.c   ****     q15_t  qC15[2];
 128:ctrl_pend.c   ****     q15_t  qK15[2];
 129:ctrl_pend.c   ****     q15_t  qL15[2];
 130:ctrl_pend.c   ****     q15_t  qD15;
 131:ctrl_pend.c   ****     q15_t  qKx15;
 132:ctrl_pend.c   **** 
 133:ctrl_pend.c   ****     /* Pre-convertidos Q7 */
 134:ctrl_pend.c   ****     q7_t   qA7[4];
 135:ctrl_pend.c   ****     q7_t   qB7[2];
 136:ctrl_pend.c   ****     q7_t   qC7[2];
 137:ctrl_pend.c   ****     q7_t   qK7[2];
 138:ctrl_pend.c   ****     q7_t   qL7[2];
 139:ctrl_pend.c   ****     q7_t   qD7;
 140:ctrl_pend.c   ****     q7_t   qKx7;
 141:ctrl_pend.c   **** 
 142:ctrl_pend.c   **** } CtrlLoop;
