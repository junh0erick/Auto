 362:ctrl_pend.c   **** 
 363:ctrl_pend.c   **** static void ss_predict_q31(CtrlLoop *lp, const float x[2], float u, float z[2])
 364:ctrl_pend.c   **** {
 365:ctrl_pend.c   ****     float qs = lp->q_scale;
 366:ctrl_pend.c   ****     q31_t xq[2], Buq[2];
 367:ctrl_pend.c   ****     q63_t dot;
 368:ctrl_pend.c   **** 
 369:ctrl_pend.c   ****     xq[0] = flt_to_q31n(x[0] / qs);
 370:ctrl_pend.c   ****     xq[1] = flt_to_q31n(x[1] / qs);
 371:ctrl_pend.c   ****     q31_t uq = flt_to_q31n(u / qs);
 372:ctrl_pend.c   **** 
 373:ctrl_pend.c   ****     /* B·u: arm_scale_q31 escala el vector B por el escalar u.
 374:ctrl_pend.c   ****        Resultado: Buq[i] = (B_q31[i] × uq) >> 31 → Q31 */
 375:ctrl_pend.c   ****     arm_scale_q31(lp->qB31, uq, 0, Buq, 2u);
 376:ctrl_pend.c   **** 
ARM GAS  C:\Users\user\AppData\Local\Temp\cc6TIdBD.s 			page 17


 377:ctrl_pend.c   ****     /* Fila 0: A[0..1]·x */
 378:ctrl_pend.c   ****     arm_dot_prod_q31(&lp->qA31[0], xq, 2u, &dot);
 379:ctrl_pend.c   ****     q31_t Ax0 = (q31_t)(dot >> 17);
 380:ctrl_pend.c   ****     z[0] = q31_to_flt(qsat31((q63_t)Ax0 + Buq[0])) * qs;
 381:ctrl_pend.c   **** 
 382:ctrl_pend.c   ****     /* Fila 1: A[2..3]·x */
 383:ctrl_pend.c   ****     arm_dot_prod_q31(&lp->qA31[2], xq, 2u, &dot);
 384:ctrl_pend.c   ****     q31_t Ax1 = (q31_t)(dot >> 17);
 385:ctrl_pend.c   ****     z[1] = q31_to_flt(qsat31((q63_t)Ax1 + Buq[1])) * qs;
 386:ctrl_pend.c   **** }
 387:ctrl_pend.c   **** 
 388:ctrl_pend.c   **** static float ss_u_cmd_q31(CtrlLoop *lp)
 389:ctrl_pend.c   **** {
 390:ctrl_pend.c   ****     float qs = lp->q_scale;
 391:ctrl_pend.c   ****     q31_t xhat_q[2];
 392:ctrl_pend.c   ****     q63_t dot;
 393:ctrl_pend.c   **** 
 394:ctrl_pend.c   ****     xhat_q[0] = flt_to_q31n(lp->xhat[0] / qs);
 395:ctrl_pend.c   ****     xhat_q[1] = flt_to_q31n(lp->xhat[1] / qs);
 396:ctrl_pend.c   **** 
 397:ctrl_pend.c   ****     arm_dot_prod_q31(lp->qK31, xhat_q, 2u, &dot);
 398:ctrl_pend.c   ****     q31_t kx = (q31_t)(dot >> 17);
 399:ctrl_pend.c   **** 
 400:ctrl_pend.c   ****     /* extra = Kx * vint_or_ref — calculado en float, luego normalizado */
 401:ctrl_pend.c   ****     float extra_f = mode_has_i(lp->mode) ? (lp->Kx * lp->vint)
 402:ctrl_pend.c   ****                                          : (lp->Kx * lp->ref);
 403:ctrl_pend.c   ****     q31_t extra_q = flt_to_q31n(extra_f / qs);
 404:ctrl_pend.c   **** 
 405:ctrl_pend.c   ****     return q31_to_flt(qsat31((q63_t)extra_q - kx)) * qs;
 406:ctrl_pend.c   **** }
 407:ctrl_pend.c   **** 
 408:ctrl_pend.c   **** static void ss_obs_pred_q31(CtrlLoop *lp, float y, float u_prev, float u_k)
 409:ctrl_pend.c   **** {
 410:ctrl_pend.c   ****     float qs = lp->q_scale;
 411:ctrl_pend.c   **** 
 412:ctrl_pend.c   ****     /* innov = y - ŷ(xhat, u_prev) */
 413:ctrl_pend.c   ****     float innov = y - ss_yhat_q31(lp, lp->xhat, u_prev);
 414:ctrl_pend.c   ****     q31_t innov_q = flt_to_q31n(innov / qs);
 415:ctrl_pend.c   **** 
 416:ctrl_pend.c   ****     /* z = A·xhat + B·u_k (resultado en float) */
 417:ctrl_pend.c   ****     float z[2];
 418:ctrl_pend.c   ****     ss_predict_q31(lp, lp->xhat, u_k, z);
 419:ctrl_pend.c   **** 
 420:ctrl_pend.c   ****     /* Linv = L × innov: arm_scale_q31(L_q, innov_q, shift=0, Linv, 2) */
 421:ctrl_pend.c   ****     q31_t Linv[2];
 422:ctrl_pend.c   ****     arm_scale_q31(lp->qL31, innov_q, 0, Linv, 2u);
 423:ctrl_pend.c   **** 
 424:ctrl_pend.c   ****     /* xhat = z + Linv (suma Q31 saturada) */
 425:ctrl_pend.c   ****     q31_t zq[2];
 426:ctrl_pend.c   ****     zq[0] = flt_to_q31n(z[0] / qs);
 427:ctrl_pend.c   ****     zq[1] = flt_to_q31n(z[1] / qs);
 428:ctrl_pend.c   ****     q31_t xhat_q[2];
 429:ctrl_pend.c   ****     arm_add_q31(zq, Linv, xhat_q, 2u);
 430:ctrl_pend.c   **** 
 431:ctrl_pend.c   ****     lp->xhat[0] = q31_to_flt(xhat_q[0]) * qs;
 432:ctrl_pend.c   ****     lp->xhat[1] = q31_to_flt(xhat_q[1]) * qs;
 433:ctrl_pend.c   **** }
